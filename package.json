{
  "name": "portfolio",
  "version": "1.12.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:ci": "jest --passWithNoTests --watch=false --coverage",
    "deploy": "ng deploy",
    "e2e": "start-server-and-test 'npm start' 'http://localhost:4200' 'cypress run --spec \"cypress/e2e/**/*.cy.ts\"'",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:run:e2e": "cypress run --spec 'cypress/e2e/**/*.cy.ts'",
    "cypress:run:component": "cypress run --component --spec 'cypress/**/*.cy.ts'",
    "cypress:run:accessibility": "cypress run --spec 'cypress/e2e/accessibility.cy.ts'",
    "cypress:run:performance": "cypress run --spec 'cypress/e2e/performance.cy.ts'",
    "cypress:run:mobile": "cypress run --spec 'cypress/e2e/mobile.cy.ts'",
    "cypress:run:visual": "cypress run --spec 'cypress/e2e/visual-regression.cy.ts'",
    "jest:preview": "node .github/scripts/preview-jest-summary.js",
    "update": "ncu -t minor -u"
  },
  "private": true,
  "dependencies": {
    "@angular-devkit/build-angular": "^21.2.16",
    "@angular-devkit/core": "^21.2.16",
    "@angular/animations": "^21.2.17",
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.2.17",
    "@angular/compiler": "^21.2.17",
    "@angular/core": "^21.2.17",
    "@angular/forms": "^21.2.17",
    "@angular/material": "^21.2.14",
    "@angular/platform-browser": "^21.2.17",
    "@angular/platform-browser-dynamic": "^21.2.17",
    "@angular/router": "^21.2.17",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^21.2.16",
    "@angular/cli": "^21.2.16",
    "@angular/compiler-cli": "^21.2.17",
    "@cypress/schematic": "^5.0.0",
    "@types/jasmine": "~6.0.0",
    "@types/jest": "^30.0.0",
    "angular-cli-ghpages": "^3.1.0",
    "cypress": "^15.17.0",
    "glob": "^9.3.5",
    "jasmine-core": "^6.3.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-junit": "^16.0.0",
    "jest-preset-angular": "^16.2.0",
    "puppeteer": "^25.1.0",
    "rimraf": "^3.0.2",
    "start-server-and-test": "^3.0.11",
    "ts-jest": "^29.4.11",
    "typescript": "~5.9.3"
  },
  "overrides": {
    "glob": "^9.3.5",
    "rimraf": "^3.0.2"
  }
}
