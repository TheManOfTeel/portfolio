{
  "name": "portfolio",
  "version": "1.12.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:ci": "jest --passWithNoTests --watch=false --coverage",
    "deploy": "ng deploy",
    "e2e": "ng e2e",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:run:e2e": "cypress run --spec 'cypress/e2e/**/*.cy.ts'",
    "cypress:run:component": "cypress run --component --spec 'cypress/**/*.cy.ts'",
    "cypress:run:accessibility": "cypress run --spec 'cypress/e2e/accessibility.cy.ts'",
    "cypress:run:performance": "cypress run --spec 'cypress/e2e/performance.cy.ts'",
    "cypress:run:mobile": "cypress run --spec 'cypress/e2e/mobile.cy.ts'",
    "cypress:run:visual": "cypress run --spec 'cypress/e2e/visual-regression.cy.ts'",
    "karma:validate": "node .github/scripts/validate-karma-setup.js",
    "karma:preview": "node .github/scripts/preview-karma-summary.js",
    "update": "ncu -t minor -u"
  },
  "private": true,
  "dependencies": {
    "@angular-devkit/build-angular": "^21.2.7",
    "@angular-devkit/core": "^21.2.7",
    "@angular/animations": "^21.2.8",
    "@angular/cdk": "^21.2.6",
    "@angular/common": "^21.2.8",
    "@angular/compiler": "^21.2.8",
    "@angular/core": "^21.2.8",
    "@angular/forms": "^21.2.8",
    "@angular/material": "^21.2.6",
    "@angular/platform-browser": "^21.2.8",
    "@angular/platform-browser-dynamic": "^21.2.8",
    "@angular/router": "^21.2.8",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.8",
    "@cypress/schematic": "^5.0.0",
    "@types/jasmine": "~6.0.0",
    "@types/jest": "^30.0.0",
    "@types/karma": "^6.3.9",
    "angular-cli-ghpages": "^3.0.2",
    "cypress": "^15.13.1",
    "glob": "^9.3.5",
    "jasmine-core": "^6.2.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-junit": "^16.0.0",
    "jest-preset-angular": "^16.1.4",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "karma-junit-reporter": "^2.0.1",
    "puppeteer": "^24.40.0",
    "rimraf": "^3.0.0",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.3"
  },
  "overrides": {
    "glob": "^9.3.5",
    "rimraf": "^3.0.0"
  }
}
